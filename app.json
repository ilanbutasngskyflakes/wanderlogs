{
  "expo": {
    "name": "WanderLogs",
    "slug": "WanderLogs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wanderlogs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.jkmylove.WanderLogs"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "firebaseApiKey": "AIzaSyCs9ki6EiF1Pxtm4tbGe-mAfY9zlaIlDLI",
      "firebaseAuthDomain": "wonderlogs-3a7ba.firebaseapp.com",
      "firebaseProjectId": "wonderlogs-3a7ba",
      "firebaseStorageBucket": "wonderlogs-3a7ba.firebasestorage.app",
      "firebaseMessagingSenderId": "515419366010",
      "firebaseAppId": "1:515419366010:android:cd94976b325adea83451c3",
      "cloudinaryCloudName": "dppl5yxv5",
      "cloudinaryUploadPreset": "wanderlogs",
      "router": {},
      "eas": {
        "projectId": "197b2308-c6ad-44b8-b5f1-1d4602317332"
      }
    }
  }
}
